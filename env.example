# Optional local overrides for notion-mcp.
#
# Do not put real Notion tokens in committed files. Prefer configuring tokens
# through `notion-mcp config --global user.token <token>`.

# Override the global configuration file path.
NOTION_MCP_CONFIG=

# Override the managed MCP server runtime directory.
NOTION_MCP_RUNTIME_DIR=

# Live tests only. Leave unset for normal local development and CI.
NOTION_MCP_TOKEN=
NOTION_MCP_USER_ID=
NOTION_MCP_LIVE=0
NOTION_MCP_LIVE_E2E=0
NOTION_MCP_LIVE_SERVER_E2E=0
NOTION_MCP_LIVE_PARENT_PAGE_ID=
NOTION_MCP_LIVE_DATA_SOURCE_ID=
